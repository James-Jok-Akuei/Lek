# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/lek

# Africa's Talking (SMS gateway)
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SHORTCODE=

# ML service
ML_SERVICE_URL=http://localhost:8000

# Auth
JWT_SECRET=

# Backend
NODE_ENV=development
PORT=3000

# Monthly predict-then-alert scheduler (node-cron, runs 1st of month 06:00).
# Set to true in production; leave false for local dev/tests and trigger the
# cycle manually via POST /api/scheduler/run-now.
SCHEDULER_ENABLED=false
