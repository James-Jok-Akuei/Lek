# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/lek

# Set to true only when connecting to a managed Postgres that requires SSL
# (e.g. seeding a Render database from your local machine via its external URL).
# Leave false/unset for local Postgres.
DATABASE_SSL=false

# Africa's Talking (SMS gateway)
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SHORTCODE=

# ML service
ML_SERVICE_URL=http://localhost:8000

# CORS: comma-separated browser origins allowed to call the backend and ML
# service. In production set this to the deployed dashboard URL. Defaults to the
# local Vite dev server when unset, so local development needs no value here.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
JWT_SECRET=

# Initial admin password used by `node scripts/seed.js` to create the first
# admin account (username: admin). Set a strong value here. If left blank, the
# seed script generates a random strong password and prints it once.
ADMIN_INITIAL_PASSWORD=

# Backend
NODE_ENV=development
PORT=3000

# Monthly predict-then-alert scheduler (node-cron, runs 1st of month 06:00).
# Set to true in production; leave false for local dev/tests and trigger the
# cycle manually via POST /api/scheduler/run-now.
SCHEDULER_ENABLED=false
